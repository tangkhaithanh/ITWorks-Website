model ReportStatusHistory {
  id                    BigInt        @id @default(autoincrement())
  report_id             BigInt
  changed_by_account_id BigInt
  from_status           ReportStatus?
  to_status             ReportStatus
  note                  String?       @db.Text
  action                String?
  created_at            DateTime      @default(now())
  report                Report        @relation(fields: [report_id], references: [id], onDelete: Cascade)
  changed_by            Account       @relation("ReportStatusChangedBy", fields: [changed_by_account_id], references: [id])

  @@index([report_id, created_at])
  @@index([changed_by_account_id])
}

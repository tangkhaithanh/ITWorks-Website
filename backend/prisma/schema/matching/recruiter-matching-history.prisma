model RecruiterMatchingHistory {
  id                    BigInt                  @id @default(autoincrement())
  recruiter_id          BigInt
  job_id                BigInt?
  action_type           RecruiterMatchingAction
  job_title_snapshot    String
  company_name_snapshot String
  response_snapshot     Json
  searched_at           DateTime                @default(now())
  created_at            DateTime                @default(now())
  recruiter             Account                 @relation(fields: [recruiter_id], references: [id])
  job                   Job?                    @relation(fields: [job_id], references: [id], onDelete: SetNull)

  @@index([recruiter_id, searched_at])
}

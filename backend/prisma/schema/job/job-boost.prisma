model JobBoost {
  id         BigInt      @id @default(autoincrement())
  job_id     BigInt
  company_id BigInt
  tier       BoostTier
  credits    Int
  start_at   DateTime
  end_at     DateTime
  status     BoostStatus @default(active)
  created_at DateTime    @default(now())
  company    Company     @relation(fields: [company_id], references: [id])
  job        Job         @relation(fields: [job_id], references: [id])
}

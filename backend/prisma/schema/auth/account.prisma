model Account {
  id                         BigInt               @id @default(autoincrement())
  email                      String               @unique
  password                   String
  role                       Role
  status                     Status               @default(active)
  refreshToken               String?
  must_change_password       Boolean              @default(false)
  created_at                 DateTime             @default(now())
  updated_at                 DateTime             @updatedAt
  user                       User?
  company                    Company?
  notifications              Notification[]
  admin_logs                 AdminLog[]
  conversations_as_applicant Conversation[]       @relation("ConvApplicant")
  conversations_as_recruiter Conversation[]       @relation("ConvRecruiter")
  messages_sent              Message[]            @relation("MessageSender")
  potential_candidates       PotentialCandidate[]
}

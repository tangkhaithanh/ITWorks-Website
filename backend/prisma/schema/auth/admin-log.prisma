model AdminLog {
  id          BigInt     @id @default(autoincrement())
  admin_id    BigInt
  action      String
  target_type TargetType
  target_id   BigInt?
  created_at  DateTime   @default(now())
  updated_at  DateTime   @updatedAt
  admin       Account    @relation(fields: [admin_id], references: [id])
}

model User {
  id               BigInt     @id @default(autoincrement())
  account_id       BigInt     @unique
  full_name        String
  phone            String?
  dob              DateTime?
  gender           Gender?
  address          String?
  avatar_url       String?
  avatar_public_id String?
  created_at       DateTime   @default(now())
  updated_at       DateTime   @updatedAt
  candidate        Candidate?
  account          Account    @relation(fields: [account_id], references: [id])
}
